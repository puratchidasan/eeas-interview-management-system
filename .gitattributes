# Auto-detect text files and normalize line endings to LF in the repository
* text=auto eol=lf

# Force LF for specific types
*.java     text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.xml      text eol=lf
*.json     text eol=lf
*.md       text eol=lf
*.sh       text eol=lf
*.conf     text eol=lf
*.properties text eol=lf
Dockerfile text eol=lf
Jenkinsfile text eol=lf

# Binary files — no line ending conversion
*.jar      binary
*.class    binary
*.png      binary
*.jpg      binary
*.gif      binary
*.pdf      binary
